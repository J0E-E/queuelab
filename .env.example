# QueueLab — environment configuration template.
# Copy to `.env` and adjust. Real defaults/validation land in Epic 2 (backend/app/config.py).
# Docker Compose reads this file; every backend service reads the same variables.

# ---- Datastores ----
# Postgres (durable job + scaling-event records)
POSTGRES_USER=queuelab
POSTGRES_PASSWORD=change-me
POSTGRES_DB=queuelab
# SQLAlchemy URL (psycopg driver) the backend connects with. Host is the compose service name.
DATABASE_URL=postgresql+psycopg://queuelab:change-me@postgres:5432/queuelab

# Redis (custom queue, hot live state, pub/sub, rate limits)
REDIS_URL=redis://redis:6379/0

# ---- Guardrails: caps (TDD §5.9) ----
MAX_JOBS_PER_SUBMISSION=100
MAX_TOTAL_QUEUED=1000
MAX_WORKERS=10

# ---- Guardrails: per-session rate limits (token bucket) ----
SUBMIT_RATE_SECONDS=5
CHAOS_RATE_SECONDS=10
# Session minting throttled per client IP (so sessions can't be rotated faster than submits).
SESSION_RATE_SECONDS=5

# ---- Guest sessions (identity binding) ----
# How long a minted guest identity stays valid server-side (the submission endpoint trusts
# the handle bound here rather than the request body).
SESSION_TTL_SECONDS=86400

# ---- Queue / lease behavior ----
VISIBILITY_TIMEOUT_SECONDS=30
DEFAULT_MAX_RETRIES=3
DEFAULT_RETRY_DELAY_MS=2000

# ---- Reaper (recovery loop) ----
# How often the api process sweeps to promote due delayed jobs and requeue expired leases
# (~1-2s, like the autoscaler control loop).
REAPER_LOOP_SECONDS=2

# ---- Autoscaler thresholds ----
MIN_WORKERS=1
SCALE_UP_THRESHOLD=5
SCALE_DOWN_THRESHOLD=1
IDLE_TIMEOUT_SECONDS=30
# Control-loop tick (~1-2s per TDD §5.5).
AUTOSCALER_LOOP_SECONDS=2

# ---- Retention / TTLs (TDD §5.7, §5.9) ----
# Hot Redis job records expire after 1h; durable Postgres rows are pruned after 24h.
REDIS_JOB_TTL_SECONDS=3600
JOB_RETENTION_HOURS=24
SCALING_EVENT_RETENTION_HOURS=24

# ---- Worker liveness / registry (TDD §5.4) ----
# How often a worker refreshes its heartbeat in ql:workers (so the autoscaler can spot a
# dead worker promptly).
WORKER_HEARTBEAT_SECONDS=5

# ---- Worker image the autoscaler launches at runtime ----
WORKER_IMAGE=queuelab-worker:latest
