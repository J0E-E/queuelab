{
    "mcpServers":  {
                       "code-review-graph":  {
                                                 "command":  "cmd",
                                                 "args":  [
                                                              "/c",
                                                              "${USERPROFILE}\\.local\\bin\\code-review-graph.exe",
                                                              "serve"
                                                          ]
                                             },
                       "memory-vault":  {
                                            "command":  "docker",
                                            "args":  [
                                                         "exec",
                                                         "-i",
                                                         "memory-vault-app-1",
                                                         "python",
                                                         "-m",
                                                         "src.mcp"
                                                     ]
                                        },
                       "playwright":  {
                                          "command":  "docker",
                                          "args":  [
                                                       "run",
                                                       "-i",
                                                       "--rm",
                                                       "--init",
                                                       "mcr.microsoft.com/playwright/mcp:latest"
                                                   ]
                                      }
                   }
}
