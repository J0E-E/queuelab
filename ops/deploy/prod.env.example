# QueueLab production environment — TEMPLATE (Epic 19).
#
# Copy this to `prod.env` ON THE HOST (it is the production secret, never committed) and fill
# the real values. The CodeDeploy ApplicationStart hook expects it next to the compose files,
# and the override (docker-compose.prod.yml) reads it both for top-level ${...} interpolation
# (image tags, registry) and as the per-service env_file.
#
#   cp ops/deploy/prod.env.example prod.env   # then edit
#
# For this learning lab the prod secret lives in this host file. Moving these to SSM Parameter
# Store / Secrets Manager is the obvious hardening step (noted in ops/deploy/DEPLOY.md).

# --- Image source (set by the deploy) --------------------------------------------------
# Account ECR registry host, e.g. 123456789012.dkr.ecr.us-east-1.amazonaws.com
# The deploy's BeforeInstall hook derives this from the instance identity + region.
ECR_REGISTRY=123456789012.dkr.ecr.us-east-1.amazonaws.com
# Image tag to run — the commit SHA CodeBuild stamped. The deploy hook overwrites this per run.
IMAGE_TAG=latest

# --- App database / cache --------------------------------------------------------------
# Postgres connection. Host `postgres` is the compose service; password must match POSTGRES_PASSWORD.
DATABASE_URL=postgresql+psycopg://queuelab:CHANGE-ME-STRONG-PASSWORD@postgres:5432/queuelab
REDIS_URL=redis://redis:6379/0
# Postgres superuser password — the ONLY real secret here. Use a strong value.
POSTGRES_PASSWORD=CHANGE-ME-STRONG-PASSWORD

# --- TLS / domain ----------------------------------------------------------------------
# Public hostname (matches infra/variables.tf domain_name and the Route53 A record).
DOMAIN=queuelab.joeyshub.com
# Email Let's Encrypt uses for expiry notices.
CERTBOT_EMAIL=you@example.com
# Set to 1 to issue against the Let's Encrypt STAGING CA (untrusted, no rate limits) for a
# dry run; unset/0 for the real cert. See DEPLOY.md cert troubleshooting.
CERTBOT_STAGING=0

# --- Worker autoscaling ----------------------------------------------------------------
# The image the autoscaler launches for each worker. The deploy's BeforeInstall hook OVERWRITES
# this per run to pin the same commit SHA as the api/autoscaler, and ApplicationStart pulls it
# onto the host (the worker is not a compose service, so `compose pull` never fetches it). The
# value here is only a placeholder for a brand-new host before the first deploy.
WORKER_IMAGE=123456789012.dkr.ecr.us-east-1.amazonaws.com/queuelab-worker:latest
# The compose network workers join to reach redis/postgres (<project>_default; project=queuelab).
WORKER_NETWORK=queuelab_default
WORKER_COMPOSE_PROJECT=queuelab

# --- Data persistence ------------------------------------------------------------------
# Root path of the separate EBS data volume (matches infra/variables.tf data_volume_mount_path).
DATA_ROOT=/mnt/queuelab-data
